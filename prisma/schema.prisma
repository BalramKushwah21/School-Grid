generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. SYSTEM & MULTI-TENANCY (SAAS CORE)
// ==========================================

model School {
  id               String   @id @default(cuid())
  schoolName       String
  subdomain        String   @unique
  schoolType       String   // e.g., Primary, Secondary, K-12
  adminName        String?
  udiseCode        String   @unique
  phone            String
  email            String   @unique
  city             String
  district         String
  state            String
  address          String
  pincode          String
  logo             String?
  subscriptionPlan String   @default("BASIC")
  isActive         Boolean  @default(true)

  // Relationships (One School -> Many Entities)
  users            User[]
  teachers         Teacher[]
  students         Student[]
  families         Family[] 
  academicProfiles AcademicProfile[]
  medicalProfiles  MedicalProfile[]
  feeRecords       FeeRecord[]
  transportProfiles TransportProfile[]
  documentArchives DocumentArchive[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  userRole  UserRole
  username  String?   @unique
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)

  // Tenant ID
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Link to specific roles
  teacherProfile Teacher?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([email])
}

model Teacher {
  id               String   @id @default(cuid())
  
  schoolId         String 
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 1. Personal Details
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           Gender
  email            String   @unique
  phone            String
  address          String?
  nationalIdNumber String?  @unique // For Aadhar/ID mappings

  // 2. Professional Details
  employeeId       String
  designation      String
  department       String
  dateOfJoining    DateTime
  qualification    String
  experienceYears  Int      @default(0)
  isClassTeacher   Boolean  @default(false)
  status           String   @default("Active")

  // 3. Payroll & Bank Details
  basicSalary      Decimal  @default(0.00) @db.Decimal(10, 2)
  bankName         String?
  accountNumber    String?
  ifscCode         String?
  panNumber        String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([schoolId, employeeId]) // Prevents duplicate Employee IDs within the same school
  @@index([schoolId])
}

// ==========================================
// 2. FAMILY & PARENT DYNAMICS
// ==========================================

model Family {
  id                   String @id @default(cuid())
  schoolId             String
  school               School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  parentsMaritalStatus MaritalStatus @default(MARRIED)
  legalCustodyHolder   Custody       @default(BOTH)

  fatherName           String
  fatherMobile         String
  fatherOccupation     String?
  fatherIncome         String?
  fatherEmail          String?
  
  motherName           String
  motherMobile         String
  motherOccupation     String?
  motherEmail          String?

  siblingStudyingHere  Boolean @default(false)
  siblingDetails       String?

  address              Address?
  students             Student[] 

  createdAt            DateTime @default(now())

  @@index([schoolId])
}

model Address {
  id       String @id @default(cuid())
  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  houseNo  String?
  street   String
  city     String
  district String
  state    String
  pincode  String
}

// ==========================================
// 3. STUDENT CORE
// ==========================================

model Student {
  id                 String @id @default(cuid())

  schoolId           String
  school             School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  familyId           String
  family             Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  rollNumber         String?
  firstName          String
  middleName         String?
  lastName           String
  admissionDate      DateTime
  gender             Gender
  dateOfBirth        DateTime
  bloodGroup         String?
  religion           String?
  category           Category
  nationality        String   @default("Indian")
  isStaffChild       Boolean  @default(false)
  identificationMark String?
  nationalIdNumber   String?  @unique // Aadhar mapped here
  abcId              String?
  panNumber          String?

  // Profiles (One-to-One Relationships)
  academicProfile    AcademicProfile?
  medicalProfile     MedicalProfile?
  feeRecord          FeeRecord?
  transportProfile   TransportProfile?
  documents          DocumentArchive?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schoolId, rollNumber])
  @@index([schoolId])
}

// ==========================================
// 4. STUDENT SUB-PROFILES (1-to-1)
// ==========================================

model AcademicProfile {
  id                   String  @id @default(cuid())
  schoolId             String
  school               School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId            String  @unique
  student              Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  currentClass         String
  section              String?
  academicSession      String
  udiseNumber          String?
  
  previousSchool       String?
  previousClass        String?
  previousUdiseCode    String?
  previousSchoolMedium String?
  tcNumber             String?
  boardRegistrationNo  String?

  @@index([schoolId])
}

model MedicalProfile {
  id                         String  @id @default(cuid())
  schoolId                   String
  school                     School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId                  String  @unique
  student                    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  emergencyContactName       String
  emergencyContactNumber     String
  relationWithStudent        String
  familyDoctorName           String?
  familyDoctorContactNumber  String?
  preferredHospital          String?
  medicalConditions          String? @db.Text
  allergies                  String?

  @@index([schoolId])
}

model FeeRecord {
  id                  String       @id @default(cuid())
  schoolId            String
  school              School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId           String       @unique
  student             Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeCategory         FeeCategory  @default(GENERAL)
  scholarship         Boolean      @default(false)
  concessionDetails   String?      @db.Text

  admissionFeePaid    Decimal      @default(0.00) @db.Decimal(10, 2)
  transportFeePaid    Decimal?     @default(0.00) @db.Decimal(10, 2)
  securityDepositPaid Decimal?     @default(0.00) @db.Decimal(10, 2)
  
  tuitionFeeCycle     TuitionCycle @default(QUARTERLY)
  paymentMode         PaymentMode  @default(CASH)

  // Bank Details
  bankName            String?
  accountNumber       String?
  ifscCode            String?
  branchNameAndCode   String?

  @@index([schoolId])
}

model TransportProfile {
  id          String  @id @default(cuid())
  schoolId    String
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String  @unique
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  needTransport Boolean @default(false)
  pickupPoint   String?
  route         String?

  @@index([schoolId])
}

model DocumentArchive {
  id                     String  @id @default(cuid())
  schoolId               String
  school                 School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId              String  @unique
  student                Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  studentPhotoUrl        String?
  birthCertificateUrl    String?
  idCardCopyUrl          String? 
  previousMarksheetUrl   String?
  transferCertificateUrl String? 
  parentIdCopyUrl        String?

  @@index([schoolId])
}

// ==========================================
// 5. ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Category {
  GENERAL
  OBC
  SC
  ST
}

enum MaritalStatus {
  MARRIED
  SINGLE
  DIVORCED
  WIDOWED
}

enum Custody {
  BOTH
  FATHER
  MOTHER
  GUARDIAN
}

enum FeeCategory {
  GENERAL
  STAFF_DISCOUNT
  SIBLING_DISCOUNT
  EWS
  MERIT
}

enum TuitionCycle {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
}