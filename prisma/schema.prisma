generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}


model User {

  id       String @id @default(cuid())
  name     String
  userRole String
  email    String @unique
  password String

  school   Schooldata?
}

model Schooldata {
  id               String @id @default(cuid())
  schoolName       String
  subdomain        String @unique
  schoolType       String
  adminName        String?
  udiseCode        String @unique
  phone            String
  email            String @unique
  city             String
  district         String
  state            String
  address          String
  pincode          String
  logo             String?
  subscriptionPlan String

  userId           String @unique
  user             User @relation(fields: [userId], references: [id])

  teachers         Teacher[]
  students         Student[]
}

model Teacher {
  id              String @id @default(cuid())

  schoolId        String
  school          Schooldata @relation(fields: [schoolId], references: [id])
}

model Student {
  id              String @id @default(cuid())
  fisrt_name      String
  middle_name     String?
  last_name       String
  admission_date  String
  gender          String
  date_of_birth   String
  blood_group     String?
  category        String
  nationality     String?
  staff_child     String?
  visible_identification_mark String?
  aadhar_number   String?
  class           String
  section         String
  academic_session String
  previous_school String?
  previous_school_median String?




  schoolId String
  school   Schooldata @relation(fields: [schoolId], references: [id])

  parents  Parent[]
}

model Parent {
  id       String @id @default(cuid())
  

  students Student[]
}