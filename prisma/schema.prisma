generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. SYSTEM & MULTI-TENANCY (SAAS CORE)
// ==========================================

model School {
  id               String   @id @default(cuid())
  schoolName       String
  subdomain        String   @unique
  schoolType       String   // e.g., Primary, Secondary, K-12
  adminName        String?
  udiseCode        String   @unique
  phone            String
  email            String   @unique
  city             String
  district         String
  state            String
  address          String
  pincode          String
  logo             String?
  subscriptionPlan String   @default("BASIC")

  // Relationships (One School -> Many Users/Teachers/Students)
  users            User[]
  teachers         Teacher[]
  students         Student[]
  families         Family[] 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  userRole  UserRole 
  email     String   @unique
  password  String

  // Tenant ID (Removed @unique because many users belong to one school)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Performance Optimization
  @@index([schoolId])
}

model Teacher {
  id        String @id @default(cuid())
  
  // Tenant ID (Removed @unique)
  schoolId  String 
  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  email     String @unique
  phone     String

  @@index([schoolId])
}

// ==========================================
// 2. FAMILY & PARENT DYNAMICS
// ==========================================

model Family {
  id                   String @id @default(cuid())
  schoolId             String
  school               School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  parentsMaritalStatus MaritalStatus @default(MARRIED)
  legalCustodyHolder   Custody       @default(BOTH)

  fatherName           String
  fatherContactNo      String
  fatherOccupation     String?
  fatherIncome         String?
  fatherEmail          String?

  motherName           String
  motherContactNo      String
  motherOccupation     String?
  motherEmail          String?

  address              Address?
  students             Student[] 

  createdAt            DateTime @default(now())

  @@index([schoolId])
}

model Address {
  id       String @id @default(cuid())
  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  locality String
  city     String
  district String
  state    String
  pincode  String
}

// ==========================================
// 3. STUDENT CORE
// ==========================================

model Student {
  id                 String @id @default(cuid())

  // Tenancy & Family Links (Removed @unique from schoolId)
  schoolId           String
  school             School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  familyId           String
  family             Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  rollNumber         String?
  firstName          String
  middleName         String?
  lastName           String
  admissionDate      DateTime
  gender             Gender
  dateOfBirth        DateTime
  bloodGroup         String?
  category           Category
  nationality        String   @default("Indian")
  isStaffChild       Boolean  @default(false)
  identificationMark String?
  aadharNumber       String?  @unique

  // Profiles
  academicProfile    AcademicProfile?
  medicalProfile     MedicalProfile?
  feeRecord          FeeRecord?
  transportProfile   TransportProfile?
  documents          DocumentArchive?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schoolId, rollNumber])
  @@index([schoolId])
}

// ==========================================
// 4. STUDENT SUB-PROFILES (1-to-1)
// ==========================================

model AcademicProfile {
  id                   String  @id @default(cuid())
  studentId            String  @unique
  student              Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  currentClass         String
  section              String
  academicSession      String
  previousSchool       String?
  previousSchoolMedium String?
  tcNumber             String?
  boardRegistrationNo  String?
}

model MedicalProfile {
  id                         String  @id @default(cuid())
  studentId                  String  @unique
  student                    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  emergencyContactName       String
  emergencyContactNumber     String
  relationWithStudent        String
  familyDoctorName           String?
  familyDoctorContactNumber  String?
  preferredHospital          String?
  medicalConditionsAllergies String? @db.Text
}

model FeeRecord {
  id                  String       @id @default(cuid())
  studentId           String       @unique
  student             Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeCategory         FeeCategory  @default(GENERAL)
  scholarship         Boolean      @default(false)
  concessionDetails   String?      @db.Text

  admissionFeePaid    Decimal      @default(0.00) @db.Decimal(10, 2)
  securityDepositPaid Decimal?     @default(0.00) @db.Decimal(10, 2)
  tuitionFeeCycle     TuitionCycle @default(QUARTERLY)
  paymentMode         PaymentMode  @default(CASH)
}

model TransportProfile {
  id          String  @id @default(cuid())
  studentId   String  @unique
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  needTransport Boolean @default(false)
  pickupPoint   String?
  route         String?
}

model DocumentArchive {
  id                   String  @id @default(cuid())
  studentId            String  @unique
  student              Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  studentPhotoUrl      String?
  birthCertificateUrl  String?
  aadharCopyUrl        String?
  previousMarksheetUrl String?
}

// ==========================================
// 5. ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Category {
  GENERAL
  OBC
  SC
  ST
}

enum MaritalStatus {
  MARRIED
  SINGLE
  DIVORCED
  WIDOWED
}

enum Custody {
  BOTH
  FATHER
  MOTHER
  GUARDIAN
}

enum FeeCategory {
  GENERAL
  STAFF_DISCOUNT
  SIBLING_DISCOUNT
  EWS
  MERIT
}

enum TuitionCycle {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
}