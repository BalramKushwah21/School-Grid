generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. SYSTEM & MULTI-TENANCY (SAAS CORE)
// ==========================================

model User {
  id       String   @id @default(cuid())
  schoolId String @unique
  name     String
  userRole UserRole 
  email    String   @unique
  password String

  school School?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id               String  @id @default(cuid())
  schoolName       String
  subdomain        String  @unique
  schoolType       String // e.g., Primary, Secondary, K-12
  adminName        String?
  udiseCode        String  @unique
  phone            String
  email            String  @unique
  city             String
  district         String
  state            String
  address          String
  pincode          String
  logo             String?
  subscriptionPlan String  @default("BASIC")

  // Relation to the User who registered the school
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // School Entities
  teachers Teacher[]
  students Student[]
  families Family[] // Groups parents and siblings together

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Add teacher-specific fields here later
  firstName String
  lastName  String
  email     String @unique
  phone     String
}

// ==========================================
// 2. FAMILY & PARENT DYNAMICS
// ==========================================
// Replaces the Many-to-Many Parent structure. 
// 1 Family -> Many Students (Handles Siblings seamlessly)

model Family {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Parent Details
  parentsMaritalStatus MaritalStatus @default(MARRIED)
  legalCustodyHolder   Custody       @default(BOTH)

  fatherName       String
  fatherContactNo  String
  fatherOccupation String?
  fatherIncome     String?
  fatherEmail      String?

  motherName       String
  motherContactNo  String
  motherOccupation String?
  motherEmail      String?

  // Relations
  address  Address?
  students Student[] // Siblings in this family

  createdAt DateTime @default(now())
}

model Address {
  id       String @id @default(cuid())
  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  locality String
  city     String
  district String
  state    String
  pincode  String
}

// ==========================================
// 3. STUDENT CORE
// ==========================================

model Student {
  id String @id @default(cuid())

  // Tenancy & Family Links
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Core Identity
  rollNumber         String?
  firstName          String
  middleName         String?
  lastName           String
  admissionDate      DateTime
  gender             Gender
  dateOfBirth        DateTime
  bloodGroup         String?
  category           Category
  nationality        String   @default("Indian")
  isStaffChild       Boolean  @default(false)
  identificationMark String?
  aadharNumber       String?  @unique

  // 1-to-1 Extension Profiles
  academicProfile  AcademicProfile?
  medicalProfile   MedicalProfile?
  feeRecord        FeeRecord?
  transportProfile TransportProfile?
  documents        DocumentArchive?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensures roll numbers are unique PER SCHOOL, not globally
  @@unique([schoolId, rollNumber])
}

// ==========================================
// 4. STUDENT SUB-PROFILES (1-to-1)
// ==========================================

model AcademicProfile {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  currentClass    String
  section         String
  academicSession String

  previousSchool       String?
  previousSchoolMedium String?
  tcNumber             String?
  boardRegistrationNo  String?
}

model MedicalProfile {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  emergencyContactName   String
  emergencyContactNumber String
  relationWithStudent    String

  familyDoctorName           String?
  familyDoctorContactNumber  String?
  preferredHospital          String?
  medicalConditionsAllergies String? @db.Text
}

model FeeRecord {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeCategory       FeeCategory @default(GENERAL)
  scholarship       Boolean     @default(false)
  concessionDetails String?     @db.Text

  admissionFeePaid    Decimal  @default(0.00) @db.Decimal(10, 2)
  securityDepositPaid Decimal? @default(0.00) @db.Decimal(10, 2)

  tuitionFeeCycle TuitionCycle @default(QUARTERLY)
  paymentMode     PaymentMode  @default(CASH)
}

model TransportProfile {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  needTransport Boolean @default(false)
  pickupPoint   String?
  route         String?
}

model DocumentArchive {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  studentPhotoUrl      String?
  birthCertificateUrl  String?
  aadharCopyUrl        String?
  previousMarksheetUrl String?
}

// ==========================================
// 5. ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Category {
  GENERAL
  OBC
  SC
  ST
}

enum MaritalStatus {
  MARRIED
  SINGLE
  DIVORCED
  WIDOWED
}

enum Custody {
  BOTH
  FATHER
  MOTHER
  GUARDIAN
}

enum FeeCategory {
  GENERAL
  STAFF_DISCOUNT
  SIBLING_DISCOUNT
  EWS
  MERIT
}

enum TuitionCycle {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
}
